PUBLIC_HOSTNAME=assistant.example.com
ACME_EMAIL=ops@example.com

POSTGRES_DB=elowen
POSTGRES_USER=elowen
POSTGRES_PASSWORD=replace-with-long-random-password

ARANGO_ROOT_PASSWORD=replace-with-long-random-password
ELOWEN_ARANGODB_DATABASE=elowen_notes
ELOWEN_ARANGODB_USERNAME=root
# When using the root ArangoDB account, this must match ARANGO_ROOT_PASSWORD.
ELOWEN_ARANGODB_PASSWORD=replace-with-long-random-password

ELOWEN_LOG_FORMAT=json
ELOWEN_NATS_HOST_PORT=4222

# Laptop edge runtime example for Slice 12 validation.
# Use the public HTTPS endpoint for the API and an SSH tunnel for NATS:
# ssh -N -L 4222:127.0.0.1:4222 your-user@your-vps
#
# Example edge values:
# ELOWEN_API_URL=https://assistant.example.com
# ELOWEN_NATS_URL=nats://127.0.0.1:4222
