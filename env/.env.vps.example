PUBLIC_HOSTNAME=assistant.example.com
ACME_EMAIL=ops@example.com

POSTGRES_DB=elowen
POSTGRES_USER=elowen
POSTGRES_PASSWORD=replace-with-long-random-password

ARANGO_ROOT_PASSWORD=replace-with-long-random-password
ELOWEN_ARANGODB_DATABASE=elowen_notes
ELOWEN_ARANGODB_USERNAME=root
# When using the root ArangoDB account, this must match ARANGO_ROOT_PASSWORD.
ELOWEN_ARANGODB_PASSWORD=replace-with-long-random-password

ELOWEN_LOG_FORMAT=json
ELOWEN_NATS_HOST_PORT=4222
OPENAI_API_KEY=
ELOWEN_ASSISTANT_MODEL=gpt-4.1-mini
ELOWEN_ASSISTANT_BASE_URL=https://api.openai.com/v1
ELOWEN_UI_PASSWORD=
ELOWEN_UI_OPERATOR_LABEL=Operator
ELOWEN_UI_COOKIE_NAME=elowen_session
ELOWEN_UI_SESSION_DAYS=14

# VPS deploys pull prebuilt GHCR images instead of compiling on-host.
# Each service repo publishes tags:
# - main
# - latest
# - sha-<full git sha>
#
# For reproducible deploys, pin these to the submodule SHAs recorded in the
# workspace commit you are deploying.
ELOWEN_API_IMAGE=ghcr.io/elowen-assistant/elowen-api
ELOWEN_API_TAG=main
ELOWEN_NOTES_IMAGE=ghcr.io/elowen-assistant/elowen-notes
ELOWEN_NOTES_TAG=main
ELOWEN_UI_IMAGE=ghcr.io/elowen-assistant/elowen-ui
ELOWEN_UI_TAG=main

# Laptop edge runtime example for Slice 12 validation.
# Use the public HTTPS endpoint for the API and an SSH tunnel for NATS:
# ssh -N -L 4222:127.0.0.1:4222 your-user@your-vps
#
# Example edge values:
# ELOWEN_API_URL=https://assistant.example.com
# ELOWEN_NATS_URL=nats://127.0.0.1:4222
